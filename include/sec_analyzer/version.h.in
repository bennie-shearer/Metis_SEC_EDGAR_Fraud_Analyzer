#ifndef SEC_ANALYZER_VERSION_H
#define SEC_ANALYZER_VERSION_H

#define SEC_ANALYZER_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define SEC_ANALYZER_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define SEC_ANALYZER_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define SEC_ANALYZER_VERSION_STRING "@PROJECT_VERSION@"

#define SEC_ANALYZER_APP_NAME     "Metis SEC EDGAR Fraud Analyzer"
#define SEC_ANALYZER_COPYRIGHT    "Copyright (c) 2026 Bennie Shearer (Retired)"
