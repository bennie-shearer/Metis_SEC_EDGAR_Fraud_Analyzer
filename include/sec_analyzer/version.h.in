           "Author: Bennie Shearer (Retired)\n"
           SEC_ANALYZER_COPYRIGHT "\n"
           SEC_ANALYZER_LICENSE "\n"
           SEC_ANALYZER_DISCLAIMER;
}

} // namespace sec_analyzer

